{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skills Sync Manager",
  "version": "0.6.1",
  "identifier": "com.xiaoai-lazy.skills-sync-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'unsafe-inline' 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420 ws://127.0.0.1:1420",
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**", "$APPDATA/**", "$EXE/**"]
      },
      "capabilities": ["default"]
    },
    "windows": [
      {
        "title": "Skills Sync Manager",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/agent-icons/": "agent-icons/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCMDQ2NEFFRjk1NTA2MjAKUldRZ0JsWDVybVFFTzI1UEF5MHpIVUZGOGtlb1h4NVRkZFZEOTQvSWhvN1Z0cmJKb0lDN1VrN2kK",
      "endpoints": [
        "https://github.com/xiaoai-lazy/skills-sync-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
